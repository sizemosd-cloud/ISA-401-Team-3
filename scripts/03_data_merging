leftjoin_Complete_Table <- WARData |> 
  left_join(player_position, by = join_by(playerName == player_full_name)) |> 
  left_join(salary_table, by = join_by(playerName == Player)) 



innerjoin_Complete_Table <- WARData |> 
  inner_join(player_position, by = join_by(playerName == player_full_name)) |> 
  inner_join(salary_table, by = join_by(playerName == Player)) 
